APP_ENV=development
DATASET_PATH=data/manufacturing_data.csv
DATABASE_PATH=.runtime/app.db

# Optional. Leave empty to run in deterministic demo mode without LLM calls.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

LLM_DAILY_USER_LIMIT=5
LLM_DAILY_GLOBAL_LIMIT=100
LLM_MAX_OUTPUT_TOKENS=900
CORS_ORIGINS=http://127.0.0.1:8788,http://localhost:8788,http://127.0.0.1:3000,http://localhost:3000



